
{% extends "layout.njk" %}

{% set title = 'Create your job alert' %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">
        {{title}}
      </h1>

      <p>
        You can change your search criteria by amending the keywords, location or filters before creating your alert.
      </p>

      <form method="post">

        <div class="subscription-criteria">
            <div class="govuk-form-group">
                <label class="govuk-label govuk-label--s" for="jobseekers-subscription-form-keyword-field">Keywords</label><input class="govuk-input" id="jobseekers-subscription-form-keyword-field" name="jobseekers_subscription_form[keyword]" type="text">
            </div>
            <div class="autocomplete" data-controller="autocomplete" data-source="getLocationSuggestions">
                <div class="govuk-form-group location-finder__input govuk-!-margin-bottom-0">
                    <label class="govuk-label govuk-label--s" for="jobseekers-subscription-form-location-field">City, county or postcode (in England)</label>
                </div>
                <div class="autocomplete__suggestions govuk-body">
                    <div class="autocomplete__wrapper">
                        <div style="border: 0px; clip: rect(0px, 0px, 0px, 0px); height: 1px; margin-bottom: -1px; margin-right: -1px; overflow: hidden; padding: 0px; position: absolute; white-space: nowrap; width: 1px;">
                            <div aria-atomic="true" aria-live="polite" id="jobseekers-subscription-form-location-field__status--A" role="status"></div>
                            <div aria-atomic="true" aria-live="polite" id="jobseekers-subscription-form-location-field__status--B" role="status"></div>
                        </div><input aria-autocomplete="list" aria-describedby="jobseekers-subscription-form-location-field__assistiveHint" aria-expanded="false" aria-owns="jobseekers-subscription-form-location-field__listbox" autocomplete="off" class="autocomplete__input autocomplete__input--default" id="jobseekers-subscription-form-location-field" name="jobseekers_subscription_form[location]" placeholder="" role="combobox" type="text">
                        <ul class="autocomplete__menu autocomplete__menu--inline autocomplete__menu--hidden" id="jobseekers-subscription-form-location-field__listbox" role="listbox"></ul><span id="jobseekers-subscription-form-location-field__assistiveHint" style="display: none;">When autocomplete results are available use up and down arrows to review and enter to select. Touch device users, explore by touch or with swipe gestures.</span>
                        <div data-lastpass-icon-root="true" style="position: relative !important; height: 0px !important; width: 0px !important; float: left !important;"></div>
                    </div>
                </div>
            </div>
            
            <div class="govuk-form-group">
                <label class="govuk-label govuk-label--s" for="jobseekers-subscription-form-radius-field">Search radius</label><select class="govuk-select" data-change-submit="false" id="jobseekers-subscription-form-radius-field" name="jobseekers_subscription_form[radius]">
                    <option selected="selected" value="0">
                        This area only
                    </option>
                    <option value="1">
                        1 mile
                    </option>
                    <option value="5">
                        5 miles
                    </option>
                    <option value="10">
                        10 miles
                    </option>
                    <option value="15">
                        15 miles
                    </option>
                    <option value="20">
                        20 miles
                    </option>
                    <option value="25">
                        25 miles
                    </option>
                    <option value="50">
                        50 miles
                    </option>
                    <option value="100">
                        100 miles
                    </option>
                    <option value="200">
                        200 miles
                    </option>
                </select>
            </div>

            <div class="divider-bottom govuk-!-margin-bottom-6"><hr class="govuk-section-break govuk-section-break--visible"></div>


            <div class="filters-component__groups__group" data-filters-target="group" data-group="education_phase">
                <div>
                    <div class="govuk-form-group">
                        <fieldset class="govuk-fieldset">
                            <legend class="govuk-fieldset__legend govuk-fieldset__legend--s"></legend>
                            <h3 class="govuk-fieldset__heading"><legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Education phase</legend></h3>
                            <div class="govuk-checkboxes" data-module="govuk-checkboxes">
                                <input autocomplete="off" name="jobseekers_subscription_form[phases][]" type="hidden" value="">
                                <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-phases-nursery-field" name="jobseekers_subscription_form[phases][]" type="checkbox" value="nursery"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-phases-nursery-field">Nursery</label>
                                </div>
                                <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-phases-primary-field" name="jobseekers_subscription_form[phases][]" type="checkbox" value="primary"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-phases-primary-field">Primary school</label>
                                </div>
                                <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-phases-secondary-field" name="jobseekers_subscription_form[phases][]" type="checkbox" value="secondary"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-phases-secondary-field">Secondary school</label>
                                </div>
                                <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-phases-sixth-form-or-college-field" name="jobseekers_subscription_form[phases][]" type="checkbox" value="sixth_form_or_college"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-phases-sixth-form-or-college-field">Sixth form</label>
                                </div>
                                <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-phases-through-field" name="jobseekers_subscription_form[phases][]" type="checkbox" value="through"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-phases-through-field">All through school</label>
                                </div>
                                <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-phases-through-field" name="jobseekers_subscription_form[phases][]" type="checkbox" value="furthereducation"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-phases-through-field">Further education or college</label>
                                </div>
                            </div>
                        </fieldset>
                    </div>
                </div>
            </div>

            <div class="filters-component__groups__group" data-filters-target="group" data-group="working_patterns">
                <div>
                    <div class="govuk-form-group">
                        <fieldset class="govuk-fieldset">
                            <legend class="govuk-fieldset__legend govuk-fieldset__legend--s"></legend>
                            <h3 class="govuk-fieldset__heading"><legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Working pattern</legend></h3>
                            <div class="govuk-checkboxes" data-module="govuk-checkboxes">
                                <input autocomplete="off" name="jobseekers_subscription_form[working_patterns][]" type="hidden" value="">
                                <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-working-patterns-full-time-field" name="jobseekers_subscription_form[working_patterns][]" type="checkbox" value="full_time"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-working-patterns-full-time-field">Full time</label>
                                </div>
                                <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-working-patterns-part-time-field" name="jobseekers_subscription_form[working_patterns][]" type="checkbox" value="part_time"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-working-patterns-part-time-field">Part time</label>
                                </div>
                                <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-working-patterns-part-time-field" name="jobseekers_subscription_form[working_patterns][]" type="checkbox" value="part_time"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-working-patterns-part-time-field">Job share</label>
                                </div>
                            </div>
                        </fieldset>
                    </div>
                </div>
            </div>

            <div class="filters-component__groups__group" data-filters-target="group" data-group="ect_statuses">
                <div>
                    <div class="govuk-form-group">
                        <fieldset class="govuk-fieldset">
                            <legend class="govuk-fieldset__legend govuk-fieldset__legend--s"></legend>
                            <h3 class="govuk-fieldset__heading"><legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Suitable for early career teachers</legend></h3>
                            <div class="govuk-checkboxes" data-module="govuk-checkboxes">
                                <input autocomplete="off" name="jobseekers_subscription_form[ect_statuses][]" type="hidden" value="">
                                <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-ect-statuses-ect-suitable-field" name="jobseekers_subscription_form[ect_statuses][]" type="checkbox" value="ect_suitable"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-ect-statuses-ect-suitable-field">Suitable for early career teachers</label>
                                </div>
                            </div>
                        </fieldset>
                    </div>
                </div>
            </div>

            <div class="filters-component__groups__group" data-filters-target="group" data-group="international">
                <div>
                    <div class="govuk-form-group">
                        <fieldset class="govuk-fieldset">
                            <legend class="govuk-fieldset__legend govuk-fieldset__legend--s"></legend>
                            <h3 class="govuk-fieldset__heading"><legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Visa sponsorship</legend></h3>
                            <div class="govuk-checkboxes" data-module="govuk-checkboxes">
                                <input autocomplete="off" name="jobseekers_subscription_form[international][]" type="hidden" value="">
                                <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-ect-statuses-ect-suitable-field" name="jobseekers_subscription_form[international][]" type="checkbox" value="ect_suitable"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-ect-statuses-ect-suitable-field">Only send alerts for jobs with visa sponsorship</label>
                                </div>
                            </div>
                        </fieldset>
                    </div>
                </div>
            </div>

            <div class="filters-component__groups__group" data-filters-target="group" data-group="teaching_job_roles">
                <div>
                    <details class="govuk-details">
                        <summary class="govuk-details__summary">
                            <span class="govuk-details__summary-text"><span aria-label="Teaching and leadership job roles" title="Teaching and leadership roles">Teaching and leadership</span></span>
                        </summary>
                        <div class="govuk-details__text">
                            <div class="govuk-form-group">
                                <fieldset class="govuk-fieldset">
                                    <div class="govuk-checkboxes govuk-checkboxes--small" data-govuk-checkboxes-init="" data-module="govuk-checkboxes">
                                        <input autocomplete="off" name="jobseekers_subscription_form[teaching_job_roles][]" type="hidden" value="">
                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-teaching-job-roles-teacher-field" name="jobseekers_subscription_form[teaching_job_roles][]" type="checkbox" value="teacher"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-teaching-job-roles-teacher-field">Teacher or lecturer</label>
                                        </div>
                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-teaching-job-roles-head-of-year-or-phase-field" name="jobseekers_subscription_form[teaching_job_roles][]" type="checkbox" value="head_of_year_or_phase"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-teaching-job-roles-head-of-year-or-phase-field">Head of year or phase</label>
                                        </div>
                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-teaching-job-roles-head-of-department-or-curriculum-field" name="jobseekers_subscription_form[teaching_job_roles][]" type="checkbox" value="head_of_department_or_curriculum"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-teaching-job-roles-head-of-department-or-curriculum-field">Head of department or curriculum</label>
                                        </div>
                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-teaching-job-roles-assistant-headteacher-field" name="jobseekers_subscription_form[teaching_job_roles][]" type="checkbox" value="assistant_headteacher"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-teaching-job-roles-assistant-headteacher-field">Assistant headteacher</label>
                                        </div>
                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-teaching-job-roles-deputy-headteacher-field" name="jobseekers_subscription_form[teaching_job_roles][]" type="checkbox" value="deputy_headteacher"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-teaching-job-roles-deputy-headteacher-field">Deputy headteacher</label>
                                        </div>
                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-teaching-job-roles-headteacher-field" name="jobseekers_subscription_form[teaching_job_roles][]" type="checkbox" value="headteacher"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-teaching-job-roles-headteacher-field">Headteacher</label>
                                        </div>
                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-teaching-job-roles-sendco-field" name="jobseekers_subscription_form[teaching_job_roles][]" type="checkbox" value="sendco"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-teaching-job-roles-sendco-field">SENDCo (special educational needs and disabilities coordinator)</label>
                                        </div>
                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-teaching-job-roles-other-leadership-field" name="jobseekers_subscription_form[teaching_job_roles][]" type="checkbox" value="other_leadership"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-teaching-job-roles-other-leadership-field">Other leadership roles</label>
                                        </div>
                                    </div>
                                </fieldset>
                            </div>
                        </div>
                    </details>
                </div>
            </div>

            <div class="filters-component__groups__group" data-filters-target="group" data-group="support_job_roles">
                <div>
                    <details class="govuk-details">
                        <summary class="govuk-details__summary">
                            <span class="govuk-details__summary-text"><span aria-label="Support job roles" title="Support roles">Support</span></span>
                        </summary>
                        <div class="govuk-details__text">
                            <div class="govuk-form-group">
                                <fieldset class="govuk-fieldset">
                                    <div class="govuk-checkboxes govuk-checkboxes--small" data-govuk-checkboxes-init="" data-module="govuk-checkboxes">
                                        <input autocomplete="off" name="jobseekers_subscription_form[support_job_roles][]" type="hidden" value="">
                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-support-job-roles-teaching-assistant-field" name="jobseekers_subscription_form[support_job_roles][]" type="checkbox" value="teaching_assistant"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-support-job-roles-teaching-assistant-field">Teaching assistant</label>
                                        </div>
                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-support-job-roles-higher-level-teaching-assistant-field" name="jobseekers_subscription_form[support_job_roles][]" type="checkbox" value="higher_level_teaching_assistant"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-support-job-roles-higher-level-teaching-assistant-field">HLTA (higher level teaching assistant)</label>
                                        </div>
                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-support-job-roles-education-support-field" name="jobseekers_subscription_form[support_job_roles][]" type="checkbox" value="education_support"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-support-job-roles-education-support-field">Learning support or cover supervisor</label>
                                        </div>
                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-support-job-roles-administration-hr-data-and-finance-field" name="jobseekers_subscription_form[support_job_roles][]" type="checkbox" value="administration_hr_data_and_finance"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-support-job-roles-administration-hr-data-and-finance-field">Administration, HR, data and finance</label>
                                        </div>
                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-support-job-roles-catering-cleaning-and-site-management-field" name="jobseekers_subscription_form[support_job_roles][]" type="checkbox" value="catering_cleaning_and_site_management"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-support-job-roles-catering-cleaning-and-site-management-field">Catering, cleaning and site management</label>
                                        </div>
                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-support-job-roles-it-support-field" name="jobseekers_subscription_form[support_job_roles][]" type="checkbox" value="it_support"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-support-job-roles-it-support-field">IT support</label>
                                        </div>
                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-support-job-roles-pastoral-health-and-welfare-field" name="jobseekers_subscription_form[support_job_roles][]" type="checkbox" value="pastoral_health_and_welfare"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-support-job-roles-pastoral-health-and-welfare-field">Pastoral, health and welfare</label>
                                        </div>
                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input" id="jobseekers-subscription-form-support-job-roles-other-support-field" name="jobseekers_subscription_form[support_job_roles][]" type="checkbox" value="other_support"><label class="govuk-label govuk-checkboxes__label" for="jobseekers-subscription-form-support-job-roles-other-support-field">Other support roles</label>
                                        </div>
                                    </div>
                                </fieldset>
                            </div>
                        </div>
                    </details>
                </div>
            </div>

            <div class="filters-component__groups__group" data-filters-target="group" data-group="subjects">
                <div>
                    <details class="govuk-details">
                        <summary class="govuk-details__summary">
                            <span class="govuk-details__summary-text"><span aria-label="Subjects" title="Subjects">Subjects</span></span>
                        </summary>
                        <div class="govuk-details__text">
                            <div class="govuk-form-group">
                                
                                <fieldset class="govuk-fieldset">
                                <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">

                                    <input autocomplete="off" name="jobseekers_subscription_form[subjects][]" type="hidden" value="">

                                    <!-- Subjects -->
                                    <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="subjects-aeronautical-engineering" name="filters[subjects]" type="checkbox" value="Aeronautical engineering">
                                    <label class="govuk-label govuk-checkboxes__label" for="subjects-aeronautical-engineering">Aeronautical engineering</label>
                                    </div>

                                    <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="subjects-agriculture" name="filters[subjects]" type="checkbox" value="Agriculture/horticulture/land based studies">
                                    <label class="govuk-label govuk-checkboxes__label" for="subjects-agriculture">Agriculture/horticulture/land based studies</label>
                                    </div>

                                    <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="subjects-animal-care" name="filters[subjects]" type="checkbox" value="Animal care">
                                    <label class="govuk-label govuk-checkboxes__label" for="subjects-animal-care">Animal care</label>
                                    </div>

                                    <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="subjects-art-design" name="filters[subjects]" type="checkbox" value="Art and design">
                                    <label class="govuk-label govuk-checkboxes__label" for="subjects-art-design">Art and design</label>
                                    </div>

                                    <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="subjects-art-history" name="filters[subjects]" type="checkbox" value="Art history">
                                    <label class="govuk-label govuk-checkboxes__label" for="subjects-art-history">Art history</label>
                                    </div>

                                    <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="subjects-biochemistry" name="filters[subjects]" type="checkbox" value="Biochemistry">
                                    <label class="govuk-label govuk-checkboxes__label" for="subjects-biochemistry">Biochemistry</label>
                                    </div>

                                    <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="subjects-biology" name="filters[subjects]" type="checkbox" value="Biology">
                                    <label class="govuk-label govuk-checkboxes__label" for="subjects-biology">Biology</label>
                                    </div>

                                    <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="subjects-bsl" name="filters[subjects]" type="checkbox" value="British sign language">
                                    <label class="govuk-label govuk-checkboxes__label" for="subjects-bsl">British sign language</label>
                                    </div>

                                    <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="subjects-building-construction" name="filters[subjects]" type="checkbox" value="Building and construction">
                                    <label class="govuk-label govuk-checkboxes__label" for="subjects-building-construction">Building and construction</label>
                                    </div>

                                    <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="subjects-chemistry" name="filters[subjects]" type="checkbox" value="Chemistry">
                                    <label class="govuk-label govuk-checkboxes__label" for="subjects-chemistry">Chemistry</label>
                                    </div>

                                    <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="subjects-child-development" name="filters[subjects]" type="checkbox" value="Children's development and learning">
                                    <label class="govuk-label govuk-checkboxes__label" for="subjects-child-development">Children's development and learning</label>
                                    </div>

                                    <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="subjects-civil-engineering" name="filters[subjects]" type="checkbox" value="Civil engineering">
                                    <label class="govuk-label govuk-checkboxes__label" for="subjects-civil-engineering">Civil engineering</label>
                                    </div>

                                    <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="subjects-classics" name="filters[subjects]" type="checkbox" value="Classics">
                                    <label class="govuk-label govuk-checkboxes__label" for="subjects-classics">Classics</label>
                                    </div>

                                    <!-- (Pattern continues exactly the same) -->

                                    <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" id="subjects-spanish" name="filters[subjects]" type="checkbox" value="Spanish">
