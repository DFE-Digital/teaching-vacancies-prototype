{% extends "layout.njk" %}
{% set primaryNavId = 'profile' %}
{% set title = 'Role' %}
{% block beforeContent %}
   {{ govukBackLink({
    text: "Back",
    href: "javascript:history.back();"
  }) }}
{% endblock %}
{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-xl">
        Work history
      </span>
      <h1 class="govuk-heading-xl">
        {{title}}
      </h1>
      <p>
        If you've had more than 1 role with the same employer, add each role separately.
      </p>
      <form method="post" novalidate>
        {{ govukInput({
          id: "profile[employer]",
          name: "profile[employer]",
          label: {
            text: 'Name of school or employer',
            classes: 'govuk-label--m'
          },
          hint: {
            text: "If you worked for yourself, enter ‘self-employed’"
          }
        }) }}
        {{ govukInput({
          id: "profile[role]",
          name: "profile[role]",
          label: {
            text: 'Role',
            classes: 'govuk-label--m'
          }
        }) }}
        {{ govukInput({
          id: "profile[roleSubject]",
          name: "profile[roleSubject]",
          label: {
            text: 'Subjects and key stages taught (optional)',
            classes: 'govuk-label--m'
          }
        }) }}
        {{ govukDateInput({
          id: "profile[startDate]",
          name: "profile[startDate]",
          fieldset: {
            legend: {
              text: "Start date",
              classes: "govuk-fieldset__legend--m"
            }
          },
          hint: {
            text: "For example, 3 2011"
          },
          items: [{
            name: "profile[startDate][month]",
            label: "Month",
            classes: "govuk-input--width-2"
          }, {
            name: "profile[startDate][year]",
            label: "Year",
            classes: "govuk-input--width-4"
          }]
        }) }}

        {% set endDate %}
          {{ govukDateInput({
            id: "profile[endDate]",
            name: "profile[endDate]",
            fieldset: {
              legend: {
                text: "End date",
                classes: "govuk-fieldset__legend--m"
              }
            },
            hint: {
              text: "For example, 3 2011"
            },
            items: [{
              name: "profile[endDate][month]",
              label: "Month",
              classes: "govuk-input--width-2"
            }, {
              name: "profile[endDate][year]",
              label: "Year",
              classes: "govuk-input--width-4"
            }]
          }) }}
        {% endset %}
        
        {{ govukRadios({
          idPrefix: "profile[currentRole]",
          name: "profile[currentRole]",
          fieldset: {
            legend: {
              text: "Are you still working in this role?",
              classes: "govuk-fieldset__legend--m"
            }
          },
          value: currentRole,
          items: [{
            text: currentRoleOptions[0].text
          }, {
            text: currentRoleOptions[1].text,
            conditional: {
              html: endDate
            }
          }]
        }) }}
        {{ govukTextarea({
          id: "profile[mainduties]",
          name: "profile[mainduties]",
          rows: "8",
          label: {
            text: "Main duties",
            classes: "govuk-label--m",
            isPageHeading: true
          },
          hint: {
            text: "List all the responsibilities this role involved"
          },
          attributes: {
            'data-word-count': 'main-duties',
            'data-word-limit': '150'
          }
        }) }}
        <p class="govuk-hint" id="main-duties-remaining">You have 150 words remaining</p>

        {{ govukTextarea({
          id: "profile[description]",
          name: "profile[description]",
          rows: "4",
          label: {
            text: "Reason for leaving role",
            classes: "govuk-label--m"
          },
          hint: {
            text: "Explain why you left this role if it helps add context"
          },
          attributes: {
            'data-word-count': 'reason-for-leaving',
            'data-word-limit': '50'
          }
        }) }}
        <p class="govuk-hint" id="reason-for-leaving-remaining">You have 50 words remaining</p>
        {{ govukButton({
          text: "Save and continue"
        }) }}
        <p><a href="/profile">Cancel</a></p>
      </form>
    </div>
  </div>
{% endblock %}

{% block pageScripts %}
  <script>
    function countWords(text) {
      var words = text.trim().match(/\S+/g);
      return words ? words.length : 0;
    }

    function updateWordCount(textarea) {
      var limit = parseInt(textarea.getAttribute('data-word-limit'), 10);
      var targetId = textarea.getAttribute('data-word-count') + '-remaining';
      var target = document.getElementById(targetId);

      if (!target || isNaN(limit)) {
        return;
      }

      var remaining = Math.max(limit - countWords(textarea.value), 0);
      target.textContent = 'You have ' + remaining + ' words remaining';
    }

    document.querySelectorAll('textarea[data-word-count]').forEach(function (textarea) {
      updateWordCount(textarea);
      textarea.addEventListener('input', function () {
        updateWordCount(textarea);
      });
    });
  </script>
{% endblock %}
