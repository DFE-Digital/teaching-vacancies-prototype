    align-items: stretch;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tife-header__nav-item {
    position: relative;
  }

  .tife-header__nav-link {
    display: block;
    padding: 21px 20px 19px;
    font-size: 1rem;
    text-decoration: none;
    border-bottom: 6px solid transparent;
    font-family= Arial, Inter, sans-serif;
  }

  .tife-header__nav-link:hover,
  .tife-header__nav-link:focus {
    text-decoration: underline;
  }

  .tife-header__nav-link--active {
    border-bottom-color: #3f90c4;
  }
  

  .tife-header__menu {
    display: none;
    position: absolute;
    left: 0;
    top: 100%;
    z-index: 20;
    min-width: 250px;
    max-width: 440px;
    background: #fff;
    color: #0b0c0c;
    padding: 24px 28px;
    box-shadow: 0 8px 18px rgba(0,0,0,0.15);
