    line-height: 1.1;
  }

  .tife-header__crest {
    font-size: 29px;
    line-height: 1;
  }

  .tife-header__training-logo {
    background: #fff;
    color: #003f67;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0 12px 0 16px;
    font-size: 29px;
    font-weight: 400;
    letter-spacing: 3px;
    line-height: 1;
    clip-path: polygon(0 0, calc(100% - 24px) 0, 100% 50%, calc(100% - 24px) 100%, 0 100%);
    white-space: nowrap;
  }

  .tife-header__training-logo strong {
    background: #003f67;
    color: #fff;
    margin-left: 10px;
    padding: 7px 22px 7px 10px;
    font-size: 28px;
