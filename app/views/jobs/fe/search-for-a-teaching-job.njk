  }

  .tife-header__email a {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }

  .tife-header__email-icon {
    width: 18px;
    height: 13px;
    border: 2px solid #fff;
    position: relative;
  }

  .tife-header__email-icon::before,
  .tife-header__email-icon::after {
    content: "";
    position: absolute;
    top: 4px;
    width: 11px;
    height: 2px;
    background: #fff;
  }

  .tife-header__email-icon::before {
    left: -1px;
    transform: rotate(32deg);
  }

  .tife-header__email-icon::after {
    right: -1px;
    transform: rotate(-32deg);
  }

  .tife-header__brand-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 32px;
